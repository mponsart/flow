Options -Indexes

# Use PHP 8.5 (cPanel)
AddHandler application/x-httpd-php85 .php

# Deny access to .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to sensitive directories
<FilesMatch "\.(sql|log|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect config, models, services, controllers, database, cron directories
RewriteEngine On

RewriteRule ^(config|models|services|database|cron)/ - [F,L]

# Route all requests to index.php (except real files/directories)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Security headers
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
